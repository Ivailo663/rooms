    "axios": "^1.13.6",
    "firebase": "^12.10.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
