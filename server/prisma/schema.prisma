generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(50)
  playground_id    Int?
  email            String           @unique(map: "unique_email") @db.VarChar(50)
  rooms            Room?            @relation(fields: [playground_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  timeslot_players TimeslotPlayer[]

  @@map("accounts")
}

model Room {
  id          Int            @id(map: "playgrounds_pkey") @default(autoincrement())
  name        String
  creatorId   Int?           @map("creator_id")
  hostId      Int?           @map("host_id")
  description String?
  price       Decimal        @db.Money
  address     String         @db.VarChar(100)
  accounts    Account[]
  timeslots   RoomTimeslot[]

  @@map("rooms")
}

model RoomTimeslot {
  id               Int              @id @default(autoincrement())
  roomId           Int              @map("room_id")
  order            Int              @default(0)
  available_date   DateTime         @db.Date
  label            String           @db.VarChar(5)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?        @default(now()) @db.Timestamptz(6)
  features         Json?
  price            Decimal?         @db.Money
  message          String?          @db.VarChar(250)
  name             String           @db.VarChar(50)
  max_players      Int
  day              String           @db.VarChar(2)
  enabled          Boolean          @default(false)
  room             Room             @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_room_timeslots_room")
  timeslot_players TimeslotPlayer[]

  @@unique([roomId, available_date, label], map: "unique_room_slot")
  @@map("room_timeslots")
}

model TimeslotPlayer {
  timeslotId     Int          @map("timeslot_id")
  accountId      Int          @map("account_id")
  joined_at      DateTime?    @default(now()) @db.Timestamp(6)
  accounts       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_timeslot_players_account")
  room_timeslots RoomTimeslot @relation(fields: [timeslotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_timeslot_players_timeslot")

  @@id([timeslotId, accountId])
  @@map("timeslot_players")
}
